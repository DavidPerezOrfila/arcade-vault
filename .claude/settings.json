{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\DAVID\\.local\\bin\\graphify.EXE hook-guard search"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\DAVID\\.local\\bin\\graphify.EXE hook-guard read"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"Get-ChildItem -Path .,'C:\\Users\\david.perez\\AppData\\Local\\Temp','C:\\Users\\david.perez\\OneDrive - Timestamp - Sistemas de Informa\u00e7\u00e3o S.A' -Filter 'bash.exe.stackdump' -Recurse -Depth 3 -ErrorAction SilentlyContinue -Force | Remove-Item -Force -ErrorAction SilentlyContinue; exit 0\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy RemoteSigned -File \".claude/hooks/accumulate-edited.ps1\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy RemoteSigned -File \".claude/hooks/format-batch.ps1\""
          }
        ]
      }
    ]
  }
}